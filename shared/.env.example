# ===================== Database =====================
DATABASE_URL="postgresql://postgres:password@localhost:5432/dongdong?schema=public"

# ===================== Redis =====================
REDIS_URL="redis://localhost:6379"

# ===================== JWT =====================
JWT_SECRET="change-me-to-random-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-to-another-random-secret-min-32-chars"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ===================== OAuth =====================
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL="http://localhost:3001/api/v1/auth/oauth/kakao/callback"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/oauth/google/callback"

# ===================== File Storage (S3 / Cloudflare R2) =====================
S3_BUCKET="dongdong-uploads"
S3_REGION="ap-northeast-2"
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=  # Cloudflare R2 endpoint (leave empty for AWS S3)

# ===================== Sentry =====================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ===================== Server =====================
NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# ===================== Frontend =====================
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_WS_URL="http://localhost:3001"
